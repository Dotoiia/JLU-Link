   </item>
   <item><widget class="QLabel" name="sectionLabel"><property name="text"><string>认证信息</string></property></widget></item>
   <item>
    <layout class="QVBoxLayout" name="fieldsLayout"><property name="spacing"><number>6</number></property>
     <item><widget class="QLabel" name="fieldLabelAccount"><property name="text"><string>校园网账号</string></property></widget></item>
     <item><widget class="QLineEdit" name="lineEditAccount"><property name="placeholderText"><string>请输入账号</string></property><property name="clearButtonEnabled"><bool>true</bool></property></widget></item>
     <item><spacer name="accountSpacer"><property name="orientation"><enum>Qt::Orientation::Vertical</enum></property><property name="sizeHint"><size><width>20</width><height>4</height></size></property></spacer></item>
     <item><widget class="QLabel" name="fieldLabelPassword"><property name="text"><string>密码</string></property></widget></item>
     <item><widget class="QLineEdit" name="lineEditPass"><property name="placeholderText"><string>请输入密码</string></property><property name="echoMode"><enum>QLineEdit::EchoMode::Password</enum></property></widget></item>
     <item><spacer name="passwordSpacer"><property name="orientation"><enum>Qt::Orientation::Vertical</enum></property><property name="sizeHint"><size><width>20</width><height>4</height></size></property></spacer></item>
     <item><widget class="QLabel" name="fieldLabelMac"><property name="text"><string>MAC 地址</string></property></widget></item>
     <item><widget class="QLineEdit" name="lineEditMAC"><property name="placeholderText"><string>1A:2B:3C:4D:5E:6F</string></property><property name="inputMask"><string>&gt;HH:HH:HH:HH:HH:HH;_</string></property></widget></item>
    </layout>
   </item>
   <item><widget class="QFrame" name="separator"><property name="frameShape"><enum>QFrame::Shape::NoFrame</enum></property></widget></item>
   <item><widget class="QLabel" name="preferencesLabel"><property name="text"><string>偏好设置</string></property></widget></item>
   <item>
    <layout class="QGridLayout" name="preferencesLayout"><property name="horizontalSpacing"><number>24</number></property><property name="verticalSpacing"><number>5</number></property>
     <item row="0" column="0"><widget class="QLabel" name="connectionPreferencesLabel"><property name="text"><string>连接</string></property></widget></item>
     <item row="0" column="1"><widget class="QLabel" name="windowPreferencesLabel"><property name="text"><string>窗口</string></property></widget></item>
     <item row="1" column="0"><widget class="QCheckBox" name="checkBoxRemember"><property name="text"><string>保存登录信息</string></property><property name="toolTip"><string>在此 Mac 上保存账号和加密后的密码</string></property></widget></item>
     <item row="2" column="0"><widget class="QCheckBox" name="checkBoxAutoLogin"><property name="text"><string>启动时自动连接</string></property><property name="toolTip"><string>打开应用后自动进行校园网认证</string></property></widget></item>
     <item row="3" column="0"><widget class="QCheckBox" name="checkBoxAutoReconnect"><property name="text"><string>断线后自动重连</string></property><property name="toolTip"><string>连接意外中断后自动尝试恢复认证</string></property></widget></item>
     <item row="1" column="1"><widget class="QCheckBox" name="checkBoxNotShowWelcome"><property name="text"><string>连接后不打开通知页</string></property><property name="toolTip"><string>认证成功后不打开校园网通知网页</string></property></widget></item>
     <item row="2" column="1"><widget class="QCheckBox" name="checkBoxHideLoginWindow"><property name="text"><string>启动后仅驻留菜单栏</string></property><property name="toolTip"><string>启动时不显示主窗口，只显示菜单栏图标</string></property></widget></item>
    </layout>
   </item>
   <item><spacer name="bottomSpacer"><property name="orientation"><enum>Qt::Orientation::Vertical</enum></property><property name="sizeHint"><size><width>20</width><height>8</height></size></property></spacer></item>
   <item><widget class="QPushButton" name="pushButtonLogin"><property name="text"><string>连接校园网</string></property><property name="default"><bool>true</bool></property></widget></item>
  </layout>
 </widget>
